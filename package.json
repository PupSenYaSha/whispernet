{
  "name": "whispernet",
  "version": "1.0.0",
  "description": "Modern minimalist messenger",
  "author": "PupSenYaSha",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "start": "node scripts/start.js",
    "start:server": "npx tsx server/index.ts",
    "start:site": "node scripts/start.js --site-only",
    "dev": "node node_modules/vite/bin/vite.js",
    "build:client": "node node_modules/vite/bin/vite.js build",
    "build:electron": "node node_modules/tsx/dist/cli.mjs node_modules/typescript/bin/tsc -p electron/tsconfig.json",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap sync android",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^10.1.2",
    "@fastify/websocket": "^11.3.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "adm-zip": "^0.6.0",
    "autoprefixer": "^10.4.17",
    "canvas": "^3.2.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.whispernet.app",
    "productName": "WhisperNet",
    "directories": {
      "output": "dist/build"
    },
    "files": [
      "dist/electron/**/*",
      "dist/client/**/*",
      "dist/server/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "PupSenYaSha",
      "repo": "whispernet"
    },
    "win": {
      "target": "portable",
      "signAndEditExecutable": false,
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
